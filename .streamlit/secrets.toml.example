# Streamlit Cloud Secrets Configuration
# Copy this file to secrets.toml and fill in your actual values
# DO NOT commit secrets.toml to version control

[ollama]
# For cloud deployment, use a cloud-hosted Ollama instance or alternative AI API
base_url = "http://your-ollama-cloud-instance:11434"
model = "llama3"

# Alternative: Use OpenAI or other AI providers
# [openai]
# api_key = "your-openai-api-key"
# model = "gpt-3.5-turbo"

[tesseract]
# Path to Tesseract executable (if needed in cloud environment)
cmd = "tesseract"
